DATABASE_URL="postgresql://user:password@localhost:5432/cbt_platform"

JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
ADMIN_SESSION_SECRET="your-admin-session-secret-change-this"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Nodemailer) — choose one:
# Option 1: Gmail SMTP via App Password
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-gmail@gmail.com"
EMAIL_PASS="your-gmail-app-password"
EMAIL_FROM="RCCG CBT Platform <your-gmail@gmail.com>"

